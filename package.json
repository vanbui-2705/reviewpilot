{
  "name": "reviewpilot",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "db:seed": "npx tsx scripts/seed-db.ts",
    "db:seed:reset": "npx tsx scripts/seed-db.ts --reset",
    "db:push": "npx prisma db push --accept-data-loss",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "date-fns": "^4.1.0",
    "ioredis": "^5.11.1",
    "jose": "^5.9.0",
    "lucide-react": "^0.441.0",
    "next": "^14.2.0",
    "playwright-core": "^1.60.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0"
  }
}
